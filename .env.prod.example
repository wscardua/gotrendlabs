DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1

ORYNTH_DOMAIN=example.com,www.example.com
ORYNTH_HTTP_SITE=http://example.com
ORYNTH_HTTPS_SITE=https://example.com
ORYNTH_ALLOWED_HOSTS=example.com,www.example.com
ORYNTH_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
ORYNTH_PUBLIC_BASE_URL=https://example.com
ORYNTH_RUNTIME_CONFIG_PATH=/app/.runtime/platform_config.json

BACKEND_API_URL=http://fastapi:8001
SYSTEM_LOG_RETENTION_DAYS=90

DJANGO_POSTGRES_DB=orynth
DJANGO_POSTGRES_USER=orynth_django
DJANGO_POSTGRES_PASSWORD=change-me
DJANGO_POSTGRES_HOST=orynth-prod.xxxxxx.us-east-1.rds.amazonaws.com
DJANGO_POSTGRES_PORT=5432

FASTAPI_POSTGRES_DB=orynth
FASTAPI_POSTGRES_USER=orynth_fastapi
FASTAPI_POSTGRES_PASSWORD=change-me
FASTAPI_POSTGRES_HOST=orynth-prod.xxxxxx.us-east-1.rds.amazonaws.com
FASTAPI_POSTGRES_PORT=5432

RECAPTCHA_ENABLED=0
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
ORYNTH_SMTP_PASSWORD=
ORYNTH_SMTP_API_KEY=
OPENAI_API_KEY=
